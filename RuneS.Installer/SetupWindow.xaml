  Usage governed by your Windows license.
                        </TextBlock>
                    </ScrollViewer>

                    <CheckBox x:Name="ChkAcceptLicense" Grid.Row="4"
                              Style="{StaticResource FlatCheck}"
                              Content="I accept the terms of the License Agreement"
                              Foreground="{StaticResource SubBrush}"
                              FontFamily="Segoe UI"/>
                </Grid>

                <!-- PAGE 3 · Install options -->
                <Grid x:Name="PageOptions" Visibility="Collapsed" Margin="32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Installation Options"
                               FontSize="18" FontWeight="Light"
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="Segoe UI"/>

                    <!-- Path -->
                    <StackPanel Grid.Row="2">
                        <TextBlock Text="Install folder"
                                   Foreground="{StaticResource SubBrush}"
                                   FontFamily="Segoe UI" FontSize="11.5"
                                   Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtInstallPath"
                                     Grid.Column="0"
                                     Style="{StaticResource PathBox}"/>
                            <Button Grid.Column="2"
                                    Style="{StaticResource SecondaryBtn}"
                                    Content="Browse..."
                                    Padding="14,7"
                                    Click="BtnBrowse_Click"/>
                        </Grid>
                    </StackPanel>

                    <!-- Shortcuts -->
                    <StackPanel Grid.Row="4">
                        <TextBlock Text="Shortcuts"
                                   Foreground="{StaticResource SubBrush}"
                                   FontFamily="Segoe UI" FontSize="11.5"
                                   Margin="0,0,0,10"/>
                        <CheckBox x:Name="ChkDesktop"
                                  Style="{StaticResource FlatCheck}"
                                  Content="Create Desktop shortcut"
                                  IsChecked="True" Margin="0,0,0,10"
                                  Foreground="{StaticResource SubBrush}"
                                  FontFamily="Segoe UI"/>
                        <CheckBox x:Name="ChkStartMenu"
                                  Style="{StaticResource FlatCheck}"
                                  Content="Add to Start Menu"
                                  IsChecked="True"
                                  Foreground="{StaticResource SubBrush}"
                                  FontFamily="Segoe UI"/>
                    </StackPanel>

                    <!-- Required space note -->
                    <Border Grid.Row="6" Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource BorderBrush_}"
                            BorderThickness="1" CornerRadius="6" Padding="12,8">
                        <TextBlock x:Name="TxtSpaceInfo"
                                   Foreground="{StaticResource DimBrush}"
                                   FontFamily="Segoe UI" FontSize="11"
                                   Text="Required disk space: calculating..."/>
                    </Border>
                </Grid>

                <!-- PAGE 4 · Installing -->
                <Grid x:Name="PageInstalling" Visibility="Collapsed" Margin="32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Installing RuneS..."
                               FontSize="18" FontWeight="Light"
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="Segoe UI"/>

                    <!-- Animated R logo -->
                    <Border Grid.Row="1" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Border Width="72" Height="72" CornerRadius="18"
                                Background="#FF1A1C22"
                                BorderBrush="{StaticResource Border2Brush}"
                                BorderThickness="1">
                            <TextBlock Text="R" FontSize="36" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform x:Name="LogoPulse" ScaleX="1" ScaleY="1"
                                                    CenterX="18" CenterY="18"/>
                                </TextBlock.RenderTransform>
                                <TextBlock.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever"
                                                        AutoReverse="True">
                                                <DoubleAnimation
                                                    Storyboard.TargetName="LogoPulse"
                                                    Storyboard.TargetProperty="ScaleX"
                                                    From="1" To="1.08" Duration="0:0:1"
                                                    AutoReverse="True"/>
                                                <DoubleAnimation
                                                    Storyboard.TargetName="LogoPulse"
                                                    Storyboard.TargetProperty="ScaleY"
                                                    From="1" To="1.08" Duration="0:0:1"
                                                    AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </TextBlock.Triggers>
                            </TextBlock>
                        </Border>
                    </Border>

                    <!-- Progress -->
                    <ProgressBar x:Name="InstallBar" Grid.Row="2"
                                 Style="{StaticResource InstallProgress}"
                                 Minimum="0" Maximum="100" Value="0"/>

                    <TextBlock x:Name="TxtInstallStatus" Grid.Row="4"
                               Text="Preparing..."
                               Foreground="{StaticResource SubBrush}"
                               FontFamily="Segoe UI" FontSize="11.5"
                               TextTrimming="CharacterEllipsis"/>

                    <TextBlock x:Name="TxtInstallPct" Grid.Row="6"
                               Text="0%"
                               Foreground="{StaticResource AccentBrush}"
                               FontFamily="Segoe UI" FontSize="11"
                               HorizontalAlignment="Right"/>
                </Grid>

                <!-- PAGE 5 · Done -->
                <Grid x:Name="PageDone" Visibility="Collapsed" Margin="32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Success icon -->
                    <Border Grid.Row="1" HorizontalAlignment="Center">
                        <Border Width="64" Height="64" CornerRadius="32"
                                Background="#1A4EC94E" BorderBrush="#FF4EC94E"
                                BorderThickness="1.5">
                            <Path Width="26" Height="20" Stretch="Uniform"
                                  Fill="Transparent" Stroke="#FF4EC94E"
                                  StrokeThickness="2.2" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Data="M4 12l6 6L20 6"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                    </Border>

                    <TextBlock Grid.Row="3" Text="Installation Complete"
                               FontSize="20" FontWeight="Light"
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="Segoe UI"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="5"
                               Text="RuneS Browser has been installed successfully.&#10;You can now launch it from your Desktop or Start Menu."
                               Foreground="{StaticResource SubBrush}"
                               FontFamily="Segoe UI" FontSize="12.5"
                               TextAlignment="Center" TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Grid>

            <!-- ══ Footer / button bar ════════════════════════════════════════ -->
            <Grid Grid.Row="2" Background="{StaticResource PanelBrush}">
                <!-- Top separator -->
                <Rectangle VerticalAlignment="Top" Height="1"
                           Fill="{StaticResource BorderBrush_}"/>

                <DockPanel Margin="24,0">
                    <!-- Cancel / Back on left -->
                    <Button x:Name="BtnCancel" DockPanel.Dock="Left"
                            Style="{StaticResource SecondaryBtn}"
                            Content="Cancel" VerticalAlignment="Center"
                            Click="BtnCancel_Click"/>

                    <Button x:Name="BtnBack" DockPanel.Dock="Left"
                            Style="{StaticResource SecondaryBtn}"
                            Content="Back" Margin="8,0,0,0"
                            VerticalAlignment="Center" IsEnabled="False"
                            Click="BtnBack_Click"/>

                    <!-- Next / Install / Finish on right -->
                    <Button x:Name="BtnNext" DockPanel.Dock="Right"
                            Style="{StaticResource PrimaryBtn}"
                            Content="Next" VerticalAlignment="Center"
                            Click="BtnNext_Click"/>
                </DockPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
