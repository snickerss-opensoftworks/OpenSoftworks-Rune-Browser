<Window x:Class="RuneS.Installer.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RuneS Setup" Width="640" Height="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#FF080A0E"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0"
                      GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Colours -->
        <Color x:Key="C.Bg"       >#FF080A0E</Color>
        <Color x:Key="C.Panel"    >#FF0D0F14</Color>
        <Color x:Key="C.Card"     >#FF13151B</Color>
        <Color x:Key="C.Border"   >#FF1E2130</Color>
        <Color x:Key="C.Border2"  >#FF2E3245</Color>
        <Color x:Key="C.Accent"   >#FF4D9EFF</Color>
        <Color x:Key="C.AccentDk" >#FF2A6ECC</Color>
        <Color x:Key="C.Text"     >#FFF0F2F8</Color>
        <Color x:Key="C.Sub"      >#FF8890A4</Color>
        <Color x:Key="C.Dim"      >#FF44485A</Color>
        <Color x:Key="C.Green"    >#FF4EC94E</Color>
        <Color x:Key="C.Red"      >#FFE8223A</Color>
        <Color x:Key="C.Hover"    >#FF1E2028</Color>
        <Color x:Key="C.Press"    >#FF262830</Color>
        <Color x:Key="C.GlossT"   >#14FFFFFF</Color>
        <Color x:Key="C.GlossB"   >#00FFFFFF</Color>

        <SolidColorBrush x:Key="BgBrush"      Color="{StaticResource C.Bg}"/>
        <SolidColorBrush x:Key="PanelBrush"   Color="{StaticResource C.Panel}"/>
        <SolidColorBrush x:Key="CardBrush"    Color="{StaticResource C.Card}"/>
        <SolidColorBrush x:Key="BorderBrush_" Color="{StaticResource C.Border}"/>
        <SolidColorBrush x:Key="Border2Brush" Color="{StaticResource C.Border2}"/>
        <SolidColorBrush x:Key="AccentBrush"  Color="{StaticResource C.Accent}"/>
        <SolidColorBrush x:Key="TextBrush"    Color="{StaticResource C.Text}"/>
        <SolidColorBrush x:Key="SubBrush"     Color="{StaticResource C.Sub}"/>
        <SolidColorBrush x:Key="DimBrush"     Color="{StaticResource C.Dim}"/>
        <SolidColorBrush x:Key="GreenBrush"   Color="{StaticResource C.Green}"/>
        <SolidColorBrush x:Key="HoverBrush"   Color="{StaticResource C.Hover}"/>

        <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="{StaticResource C.AccentDk}" Offset="0"/>
            <GradientStop Color="{StaticResource C.Accent}"   Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GlossBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource C.GlossT}" Offset="0"/>
            <GradientStop Color="{StaticResource C.GlossB}" Offset="1"/>
        </LinearGradientBrush>

        <!-- Primary button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource AccentGradient}"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderBrush"      Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="12.5"/>
            <Setter Property="FontWeight"       Value="SemiBold"/>
            <Setter Property="Padding"          Value="28,9"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <Border Background="{StaticResource GlossBrush}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.72"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary / ghost button -->
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="{StaticResource SubBrush}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Border2Brush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="12.5"/>
            <Setter Property="Padding"          Value="22,8"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{StaticResource HoverBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{StaticResource TextBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FF262830"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat CheckBox -->
        <Style x:Key="FlatCheck" TargetType="CheckBox">
            <Setter Property="Foreground"       Value="{StaticResource SubBrush}"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Box" Width="16" Height="16" CornerRadius="4"
                                    Background="#FF1A1C22" BorderThickness="1"
                                    BorderBrush="{StaticResource Border2Brush}"
                                    Margin="0,0,8,0">
                                <Path x:Name="Check" Width="9" Height="7" Stretch="Uniform"
                                      Fill="Transparent" Stroke="White" StrokeThickness="2"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M2 7l4 4 8-8"
                                      Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box"   Property="Background"     Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Box"   Property="BorderBrush"    Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Check" Property="Visibility"     Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox for path input -->
        <Style x:Key="PathBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#FF1A1C22"/>
            <Setter Property="Foreground"       Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush"       Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush"   Value="#442A6ECC"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Border2Brush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="FontFamily"       Value="Segoe UI"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Padding"          Value="10,7"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          Background="Transparent"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Progress bar -->
        <Style x:Key="InstallProgress" TargetType="ProgressBar">
            <Setter Property="Height"          Value="4"/>
            <Setter Property="Background"      Value="#FF1E2130"/>
            <Setter Property="Foreground"      Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderBrush"     Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2" ClipToBounds="True">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        HorizontalAlignment="Left" CornerRadius="2"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollViewer for license text -->
        <Style x:Key="LicenseScroll" TargetType="ScrollViewer">
            <Setter Property="Background"                Value="#FF0D0F14"/>
            <Setter Property="BorderBrush"               Value="{StaticResource Border2Brush}"/>
            <Setter Property="BorderThickness"           Value="1"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>
    </Window.Resources>

    <!-- Outer border for window chrome -->
    <Border BorderBrush="{StaticResource Border2Brush}" BorderThickness="1"
            MouseLeftButtonDown="TitleBar_Drag">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>   <!-- header -->
                <RowDefinition Height="*"/>    <!-- content pages -->
                <RowDefinition Height="64"/>   <!-- footer / button bar -->
            </Grid.RowDefinitions>

            <!-- ══ Header ═══════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Background="{StaticResource PanelBrush}">
                <!-- Gloss -->
                <Border Background="{StaticResource GlossBrush}" IsHitTestVisible="False"/>
                <Border BorderBrush="{StaticResource BorderBrush_}"
                        BorderThickness="0,0,0,1" IsHitTestVisible="False"/>

                <DockPanel Margin="20,0">
                    <!-- Logo + name -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Border Width="28" Height="28" CornerRadius="7"
                                Background="#FF1A1C22"
                                BorderBrush="{StaticResource Border2Brush}"
                                BorderThickness="1" Margin="0,0,10,0">
                            <TextBlock Text="R" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="RuneS Browser" FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       FontFamily="Segoe UI"/>
                            <TextBlock x:Name="HeaderSubtitle"
                                       Text="Setup Wizard"
                                       FontSize="11"
                                       Foreground="{StaticResource SubBrush}"
                                       FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Step indicator dots -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="Dot1" Width="7" Height="7" Margin="4,0"
                                 Fill="{StaticResource AccentBrush}"/>
                        <Ellipse x:Name="Dot2" Width="7" Height="7" Margin="4,0"
                                 Fill="{StaticResource DimBrush}"/>
                        <Ellipse x:Name="Dot3" Width="7" Height="7" Margin="4,0"
                                 Fill="{StaticResource DimBrush}"/>
                        <Ellipse x:Name="Dot4" Width="7" Height="7" Margin="4,0"
                                 Fill="{StaticResource DimBrush}"/>
                        <Ellipse x:Name="Dot5" Width="7" Height="7" Margin="4,0"
                                 Fill="{StaticResource DimBrush}"/>
                    </StackPanel>

                    <!-- Window close -->
                    <Button DockPanel.Dock="Right" Width="40" Height="40"
                            Background="Transparent" BorderBrush="Transparent"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,4,0"
                            Click="BtnWindowClose_Click" FocusVisualStyle="{x:Null}"
                            ToolTip="Cancel">
                        <Path Width="9" Height="9" Stretch="Uniform" Fill="Transparent"
                              Stroke="#FF44485A" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M18 6L6 18M6 6l12 12"/>
                    </Button>
                </DockPanel>
            </Grid>

            <!-- ══ Page container ════════════════════════════════════════════ -->
            <Grid Grid.Row="1" x:Name="PageHost" Margin="0">

                <!-- PAGE 1 · Welcome -->
                <Grid x:Name="PageWelcome" Visibility="Visible" Margin="32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Welcome to RuneS Setup"
                               FontSize="20" FontWeight="Light"
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="Segoe UI"/>

                    <TextBlock Grid.Row="2"
                               Text="This wizard will guide you through the installation of RuneS Browser on your computer."
                               Foreground="{StaticResource SubBrush}"
                               FontFamily="Segoe UI" FontSize="12.5"
                               TextWrapping="Wrap"/>

                    <!-- Feature cards -->
                    <UniformGrid Grid.Row="4" Columns="3" VerticalAlignment="Top">
                        <Border Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrush_}"
                                BorderThickness="1" CornerRadius="8" Margin="0,0,8,0"
                                Padding="14,12">
                            <StackPanel>
                                <Path Width="20" Height="20" Stretch="Uniform"
                                      Fill="Transparent" Stroke="#FF4D9EFF"
                                      StrokeThickness="1.6" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z M13 2v7h7"
                                      Margin="0,0,0,8" HorizontalAlignment="Left"/>
                                <TextBlock Text="Chromium Engine"
                                           Foreground="{StaticResource TextBrush}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Powered by WebView2 for full modern web support."
                                           Foreground="{StaticResource SubBrush}"
                                           FontFamily="Segoe UI" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrush_}"
                                BorderThickness="1" CornerRadius="8" Margin="4,0,4,0"
                                Padding="14,12">
                            <StackPanel>
                                <Path Width="20" Height="20" Stretch="Uniform"
                                      Fill="Transparent" Stroke="#FF4EC94E"
                                      StrokeThickness="1.6" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z M2 12h20 M12 2c-2.76 4-2.76 16 0 20 M12 2c2.76 4 2.76 16 0 20"
                                      Margin="0,0,0,8" HorizontalAlignment="Left"/>
                                <TextBlock Text="Dark Theme"
                                           Foreground="{StaticResource TextBrush}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Beautiful dark UI inspired by top browser themes."
                                           Foreground="{StaticResource SubBrush}"
                                           FontFamily="Segoe UI" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource BorderBrush_}"
                                BorderThickness="1" CornerRadius="8" Margin="8,0,0,0"
                                Padding="14,12">
                            <StackPanel>
                                <Path Width="20" Height="20" Stretch="Uniform"
                                      Fill="Transparent" Stroke="#FFFFA040"
                                      StrokeThickness="1.6" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="M13 2L3 14h9l-1 8 10-12h-9l1-8z"
                                      Margin="0,0,0,8" HorizontalAlignment="Left"/>
                                <TextBlock Text="Lightweight"
                                           Foreground="{StaticResource TextBrush}"
                                           FontFamily="Segoe UI" FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Optimised for low-end hardware with minimal RAM usage."
                                           Foreground="{StaticResource SubBrush}"
                                           FontFamily="Segoe UI" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>

                <!-- PAGE 2 · License -->
                <Grid x:Name="PageLicense" Visibility="Collapsed" Margin="32,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="License Agreement"
                               FontSize="18" FontWeight="Light"
                               Foreground="{StaticResource TextBrush}"
                               FontFamily="Segoe UI"/>

                    <ScrollViewer Grid.Row="2" Style="{StaticResource LicenseScroll}"
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock Foreground="{StaticResource SubBrush}"
                                   FontFamily="Consolas" FontSize="11"
                                   TextWrapping="Wrap" Padding="12"
                                   LineHeight="18">
