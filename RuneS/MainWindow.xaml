<Window x:Class="RuneS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RuneS" Height="740" Width="1200" MinHeight="460" MinWidth="680"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgWindowBrush}"
        x:Name="BrowserWindow"
        StateChanged="Window_StateChanged"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="5"
                      CornerRadius="0" GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="OuterBorder"
            BorderBrush="{StaticResource BorderBrush_}"
            BorderThickness="1" SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>    <!-- 0 title bar  -->
                <RowDefinition Height="36"/>    <!-- 1 tab strip  -->
                <RowDefinition Height="2"/>     <!-- 2 load bar   -->
                <RowDefinition Height="44"/>    <!-- 3 nav bar    -->
                <RowDefinition Height="Auto"/>  <!-- 4 bookmarks  -->
                <RowDefinition Height="Auto"/>  <!-- 5 find bar   -->
                <RowDefinition Height="*"/>     <!-- 6 content    -->
                <RowDefinition Height="22"/>    <!-- 7 status bar -->
            </Grid.RowDefinitions>

            <!-- ═══════════════════════════════════════════════════════════
                 ROW 0 · Title bar
            ═══════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0" Background="{StaticResource BgTitleBrush}">
                <!-- Gloss overlay -->
                <Border Background="{StaticResource GlossBrush}" IsHitTestVisible="False"/>
                <DockPanel>
                    <!-- App identity -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="10,0,0,0">
                        <Border Width="18" Height="18" CornerRadius="5"
                                Background="{StaticResource BgHoverBrush}"
                                BorderBrush="{StaticResource BorderBrightBrush}"
                                BorderThickness="1" Margin="0,0,7,0">
                            <TextBlock Text="R" FontSize="10" FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe UI"/>
                        </Border>
                        <TextBlock Text="RuneS" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSubBrush}"
                                   VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Stretch">
                        <Button x:Name="BtnMinimize" Style="{StaticResource WinCtrlButtonStyle}"
                                ToolTip="Minimise" Click="BtnMinimize_Click">
                            <Path Width="12" Height="12" Stretch="Uniform" Fill="Transparent"
                                  StrokeThickness="1.6" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="{StaticResource IcoMinimize}"
                                  Stroke="{Binding Foreground,
                                           RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                        </Button>
                        <Button x:Name="BtnMaximize" Style="{StaticResource WinCtrlButtonStyle}"
                                ToolTip="Maximise" Click="BtnMaximize_Click">
                            <Path x:Name="MaximizeIcon" Width="11" Height="11"
                                  Stretch="Uniform" Fill="Transparent"
                                  StrokeThickness="1.6" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="{StaticResource IcoMaximize}"
                                  Stroke="{Binding Foreground,
                                           RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                        </Button>
                        <Button x:Name="BtnClose" Style="{StaticResource CloseButtonStyle}"
                                ToolTip="Close" Click="BtnClose_Click">
                            <Path Width="10" Height="10" Stretch="Uniform" Fill="Transparent"
                                  StrokeThickness="1.6" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="{StaticResource IcoClose}"
                                  Stroke="{Binding Foreground,
                                           RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                        </Button>
                    </StackPanel>
                    <Grid/>
                </DockPanel>
            </Grid>

            <!-- Title/tab separator -->
            <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                       Fill="{StaticResource SepBrush}"/>

            <!-- ═══════════════════════════════════════════════════════════
                 ROW 1 · Tab strip
            ═══════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="1" Background="{StaticResource BgTabBarBrush}">
                <!-- Gloss -->
                <Border Background="{StaticResource GlossBrush}" IsHitTestVisible="False"/>

                <DockPanel>
                    <!-- New tab -->
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource NewTabButtonStyle}"
                            ToolTip="New tab  Ctrl+T" Click="BtnNewTab_Click"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                        <Path Width="11" Height="11" Stretch="Uniform" Fill="Transparent"
                              StrokeThickness="2.2" StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="{StaticResource IcoNewTab}"
                              Stroke="{Binding Foreground,
                                       RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                    </Button>

                    <!-- Tab scroll area -->
                    <ScrollViewer x:Name="TabScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Hidden"
                                  CanContentScroll="False"
                                  PanningMode="HorizontalFirst">
                        <StackPanel x:Name="TabsPanel" Orientation="Horizontal"
                                    WindowChrome.IsHitTestVisibleInChrome="True"
                                    Margin="6,0,0,0"/>
                    </ScrollViewer>
                </DockPanel>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 ROW 2 · Load progress bar
            ═══════════════════════════════════════════════════════════════ -->
            <ProgressBar x:Name="LoadProgressBar" Grid.Row="2"
                         Style="{StaticResource LoadBarStyle}"
                         Visibility="Collapsed"/>

            <!-- ═══════════════════════════════════════════════════════════
                 ROW 3 · Navigation bar
            ═══════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="3" Background="{StaticResource BgNavBrush}">
                <!-- Gloss -->
                <Border Background="{StaticResource GlossBrush}" IsHitTestVisible="False"/>
                <Border BorderBrush="{StaticResource SepBrush}"
                        BorderThickness="0,0,0,1" Padding="6,5">
                    <DockPanel>

                        <!-- Left nav -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,2,0">

                            <Button x:Name="BtnBack" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Back  Alt+Left" IsEnabled="False"
                                    Click="BtnBack_Click">
                                <Path Width="13" Height="13" Stretch="Uniform" Fill="Transparent"
                                      StrokeThickness="2" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="{StaticResource IcoBack}"
                                      Stroke="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            </Button>

                            <Button x:Name="BtnForward" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Forward  Alt+Right" IsEnabled="False"
                                    Click="BtnForward_Click">
                                <Path Width="13" Height="13" Stretch="Uniform" Fill="Transparent"
                                      StrokeThickness="2" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="{StaticResource IcoForward}"
                                      Stroke="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            </Button>

                            <Button x:Name="BtnRefresh" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Refresh  F5" Click="BtnRefresh_Click">
                                <Path x:Name="RefreshIcon" Width="13" Height="13"
                                      Stretch="Uniform" Fill="Transparent"
                                      StrokeThickness="2" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="{StaticResource IcoRefresh}"
                                      Stroke="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            </Button>

                            <Button x:Name="BtnHome" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Home" Click="BtnHome_Click">
                                <Path Width="13" Height="13" Stretch="Uniform" Fill="Transparent"
                                      StrokeThickness="1.8" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="{StaticResource IcoHome}"
                                      Stroke="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            </Button>
                        </StackPanel>

                        <!-- Right toolbar -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="2,0,0,0">

                            <Button x:Name="BtnBookmark" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Bookmark  Ctrl+D" Click="BtnBookmark_Click">
                                <Path x:Name="BookmarkIcon" Width="13" Height="13"
                                      Stretch="Uniform" Fill="Transparent"
                                      StrokeThickness="1.8" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="{StaticResource IcoStarOutline}"
                                      Stroke="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            </Button>

                            <Button x:Name="BtnFind" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Find in page  Ctrl+F" Click="BtnFind_Click">
                                <Path Width="13" Height="13" Stretch="Uniform" Fill="Transparent"
                                      StrokeThickness="1.8" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="{StaticResource IcoFind}"
                                      Stroke="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            </Button>

                            <Button x:Name="BtnDownloads" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Downloads" Click="BtnDownloads_Click">
                                <Path Width="13" Height="13" Stretch="Uniform" Fill="Transparent"
                                      StrokeThickness="1.8" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                      Data="{StaticResource IcoDownload}"
                                      Stroke="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            </Button>

                            <Button x:Name="BtnSettings" Style="{StaticResource IconButtonStyle}"
                                    ToolTip="Settings  Alt+F" Click="BtnSettings_Click">
                                <Path Width="13" Height="13" Stretch="Uniform" Fill="Transparent"
                                      StrokeThickness="1.8" StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Data="{StaticResource IcoSettings}"
                                      Stroke="{Binding Foreground,
                                               RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                            </Button>
                        </StackPanel>

                        <!-- Address bar -->
                        <Border x:Name="AddrBarBorder"
                                Background="{StaticResource BgAddrBrush}"
                                CornerRadius="7"
                                BorderBrush="{StaticResource BorderAddrBrush}"
                                BorderThickness="1"
                                Margin="4,0" Padding="10,0">
                            <DockPanel VerticalAlignment="Center">

                                <!-- Security indicator -->
                                <Path x:Name="LockIcon" DockPanel.Dock="Left"
                                      Width="11" Height="11" Stretch="Uniform"
                                      Fill="Transparent" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="{StaticResource IcoLock}"
                                      Stroke="{StaticResource GreenBrush}"
                                      Margin="0,0,6,0" Cursor="Hand"
                                      ToolTip="Secure connection (HTTPS)"/>

                                <Path x:Name="InsecureIcon" DockPanel.Dock="Left"
                                      Width="11" Height="11" Stretch="Uniform"
                                      Fill="Transparent" StrokeThickness="1.4"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="{StaticResource IcoGlobe}"
                                      Stroke="{StaticResource TextDimBrush}"
                                      Margin="0,0,6,0" Visibility="Collapsed"/>

                                <!-- Address input -->
                                <TextBox x:Name="AddressBox"
                                         Style="{StaticResource AddressBoxStyle}"
                                         VerticalAlignment="Center"
                                         GotFocus="AddressBox_GotFocus"
                                         LostFocus="AddressBox_LostFocus"
                                         KeyDown="AddressBox_KeyDown"
                                         PreviewMouseDown="AddressBox_PreviewMouseDown"/>
                            </DockPanel>
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- ═══════════════════════════════════════════════════════════
                 ROW 4 · Bookmarks bar
            ═══════════════════════════════════════════════════════════════ -->
            <Border x:Name="BookmarksBar" Grid.Row="4"
                    Background="{StaticResource BgNavBrush}"
                    BorderBrush="{StaticResource SepBrush}"
                    BorderThickness="0,0,0,1" Padding="8,0">
                <DockPanel>
                    <Path DockPanel.Dock="Left" Width="10" Height="10" Stretch="Uniform"
                          Fill="Transparent" StrokeThickness="1.4"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoBookmarks}"
                          Stroke="{StaticResource TextDimBrush}"
                          Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <StackPanel x:Name="BookmarkItemsPanel" Orientation="Horizontal"
                                VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 ROW 5 · Find bar (collapsed by default)
            ═══════════════════════════════════════════════════════════════ -->
            <Border x:Name="FindBar" Grid.Row="5"
                    Background="{StaticResource BgFindBarBrush}"
                    BorderBrush="{StaticResource SepBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="Collapsed" Padding="8,4">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Style="{StaticResource FindBarButtonStyle}"
                            ToolTip="Close  Esc" Click="BtnFindClose_Click">
                        <Path Width="9" Height="9" Stretch="Uniform" Fill="Transparent"
                              StrokeThickness="1.8" StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="{StaticResource IcoX}"
                              Stroke="{Binding Foreground,
                                       RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                    </Button>
                    <Button DockPanel.Dock="Right" Style="{StaticResource FindBarButtonStyle}"
                            ToolTip="Next  Enter" Click="BtnFindNext_Click">
                        <Path Width="9" Height="9" Stretch="Uniform" Fill="Transparent"
                              StrokeThickness="2" StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="{StaticResource IcoArrowDown}"
                              Stroke="{Binding Foreground,
                                       RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                    </Button>
                    <Button DockPanel.Dock="Right" Style="{StaticResource FindBarButtonStyle}"
                            ToolTip="Previous  Shift+Enter" Click="BtnFindPrev_Click">
                        <Path Width="9" Height="9" Stretch="Uniform" Fill="Transparent"
                              StrokeThickness="2" StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              Data="{StaticResource IcoArrowUp}"
                              Stroke="{Binding Foreground,
                                       RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                    </Button>
                    <TextBlock x:Name="FindResultText" DockPanel.Dock="Right"
                               VerticalAlignment="Center" Margin="4,0"
                               Foreground="{StaticResource TextSubBrush}"
                               FontFamily="Segoe UI" FontSize="11"
                               Text=""/>
                    <Border Background="{StaticResource BgAddrBrush}"
                            CornerRadius="5" BorderBrush="{StaticResource BorderAddrBrush}"
                            BorderThickness="1" Padding="8,2" MaxWidth="280">
                        <TextBox x:Name="FindBox" Style="{StaticResource FindBoxStyle}"
                                 VerticalAlignment="Center"
                                 TextChanged="FindBox_TextChanged"
                                 KeyDown="FindBox_KeyDown"/>
                    </Border>
                    <TextBlock Text="Find in page" VerticalAlignment="Center"
                               Margin="0,0,8,0" Foreground="{StaticResource TextSubBrush}"
                               FontFamily="Segoe UI" FontSize="11"/>
                </DockPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 ROW 6 · WebView2 container
            ═══════════════════════════════════════════════════════════════ -->
            <Grid x:Name="WebViewContainer" Grid.Row="6"
                  Background="{StaticResource BgWindowBrush}"
                  ClipToBounds="True"/>

            <!-- ═══════════════════════════════════════════════════════════
                 ROW 7 · Status bar
            ═══════════════════════════════════════════════════════════════ -->
            <Border Grid.Row="7"
                    Background="{StaticResource BgTitleBrush}"
                    BorderBrush="{StaticResource SepBrush}"
                    BorderThickness="0,1,0,0" Padding="10,0">
                <DockPanel>
                    <TextBlock x:Name="StatusText"
                               DockPanel.Dock="Left"
                               VerticalAlignment="Center" FontSize="10.5"
                               FontFamily="Segoe UI"
                               Foreground="{StaticResource TextDimBrush}"
                               Text="Ready"/>

                    <!-- Zoom controls -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="0,0,4,0">
                        <Button x:Name="BtnZoomOut" Style="{StaticResource FindBarButtonStyle}"
                                Width="20" Height="20" ToolTip="Zoom out  Ctrl+-"
                                Click="BtnZoomOut_Click">
                            <Path Width="8" Height="8" Stretch="Uniform" Fill="Transparent"
                                  StrokeThickness="2" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="{StaticResource IcoZoomOut}"
                                  Stroke="{Binding Foreground,
                                           RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                        </Button>
                        <TextBlock x:Name="ZoomLabel"
                                   Style="{StaticResource ZoomLabelStyle}"
                                   Text="100%"
                                   Cursor="Hand" ToolTip="Double-click to reset zoom"
                                   MouseLeftButtonDown="ZoomLabel_MouseLeftButtonDown"/>
                        <Button x:Name="BtnZoomIn" Style="{StaticResource FindBarButtonStyle}"
                                Width="20" Height="20" ToolTip="Zoom in  Ctrl+="
                                Click="BtnZoomIn_Click">
                            <Path Width="8" Height="8" Stretch="Uniform" Fill="Transparent"
                                  StrokeThickness="2" StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Data="{StaticResource IcoZoomIn}"
                                  Stroke="{Binding Foreground,
                                           RelativeSource={RelativeSource AncestorType={x:Type Button}}}"/>
                        </Button>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Right"
                               Text="RuneS  ·  WebView2"
                               FontSize="10" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextDimBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               Opacity="0.6"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
