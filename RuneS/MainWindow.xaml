<Window x:Class="RuneS.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RuneS" Height="760" Width="1240"
        MinHeight="480" MinWidth="700"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{StaticResource BgWindow}"
        x:Name="BrowserWindow"
        StateChanged="Window_StateChanged"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="70" ResizeBorderThickness="5"
                      CornerRadius="0" GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <!-- Tab strip -->
            <RowDefinition Height="46"/>
            <!-- Navigation bar -->
            <RowDefinition Height="2"/>
            <!-- Progress bar -->
            <RowDefinition Height="Auto"/>
            <!-- Bookmarks -->
            <RowDefinition Height="Auto"/>
            <!-- Find bar -->
            <RowDefinition Height="*"/>
            <!-- Web content -->
            <RowDefinition Height="22"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ROW 0: TAB STRIP -->
        <Grid Grid.Row="0" Background="{StaticResource BgTabBar}">
            <Border Background="{StaticResource Gloss}" IsHitTestVisible="False"/>

            <DockPanel LastChildFill="True">
                <!-- Window controls - RIGHT -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="BtnMinimize" Style="{StaticResource WinBtn}"
                            Click="BtnMinimize_Click">
                        <Path Width="12" Height="12" Stretch="Uniform" Fill="Transparent"
                              StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="{StaticResource IcoMinimize}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                    <Button x:Name="BtnMaximize" Style="{StaticResource WinBtn}"
                            Click="BtnMaximize_Click">
                        <Path x:Name="MaxIcon" Width="11" Height="11" Stretch="Uniform"
                              Fill="Transparent" StrokeThickness="1.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="{StaticResource IcoMaximize}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                    <Button x:Name="BtnClose" Style="{StaticResource CloseBtn}"
                            Click="BtnClose_Click">
                        <Path Width="10" Height="10" Stretch="Uniform" Fill="Transparent"
                              StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="{StaticResource IcoClose}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                </StackPanel>

                <!-- New tab button -->
                <Button DockPanel.Dock="Right" Style="{StaticResource NewTabBtn}"
        Click="BtnNewTab_Click" Margin="0,0,4,0"
        WindowChrome.IsHitTestVisibleInChrome="True">
                    <Path Width="11" Height="11" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoNewTab}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>

                <!-- Tab scroll area -->
                <ScrollViewer x:Name="TabScroll"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Hidden"
                              CanContentScroll="False"
                              PanningMode="HorizontalFirst"
                              Margin="6,0,0,0">
                    <StackPanel x:Name="TabsPanel" Orientation="Horizontal"/>
                </ScrollViewer>
            </DockPanel>

            <Rectangle VerticalAlignment="Bottom" Height="1" Fill="{StaticResource Sep}"/>
        </Grid>

        <!-- ROW 1: NAVIGATION BAR (Chrome style) -->
        <Grid Grid.Row="1" Background="{StaticResource BgNav}">
            <Border Background="{StaticResource Gloss}" IsHitTestVisible="False"/>
            <Border BorderBrush="{StaticResource Sep}" BorderThickness="0,0,0,1" Padding="8,6">
                <DockPanel>
                    <!-- Left: Nav buttons -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,8,0">
                        <Button x:Name="BtnBack" Style="{StaticResource IconBtn}"
                        IsEnabled="False" Click="BtnBack_Click" ToolTip="Back  Alt+Left"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Width="14" Height="14" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoBack}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                        <Button x:Name="BtnForward" Style="{StaticResource IconBtn}"
                        IsEnabled="False" Click="BtnForward_Click" ToolTip="Forward  Alt+Right"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Width="14" Height="14" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoForward}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                        <Button x:Name="BtnRefresh" Style="{StaticResource IconBtn}"
                        Click="BtnRefresh_Click" ToolTip="Refresh  F5"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path x:Name="RefreshIcon" Width="14" Height="14" Stretch="Uniform"
                          Fill="Transparent" StrokeThickness="2"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoRefresh}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                        <Button x:Name="BtnHome" Style="{StaticResource IconBtn}"
                        Click="BtnHome_Click" ToolTip="Home"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Width="14" Height="14" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoHome}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                    </StackPanel>

                    <!-- Right: Extension, Downloads, Menu -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="8,0,0,0">
                        <Button x:Name="BtnExtensions" Style="{StaticResource IconBtn}"
                        Click="BtnExtensions_Click" ToolTip="Extensions"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Width="14" Height="14" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoExtensions}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>

                        <Button x:Name="BtnBookmark" Style="{StaticResource IconBtn}"
                        Click="BtnBookmark_Click" ToolTip="Bookmark  Ctrl+D"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path x:Name="BookmarkIcon" Width="14" Height="14" Stretch="Uniform"
                          Fill="Transparent" StrokeThickness="1.8"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoStarOutline}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>

                        <Button x:Name="BtnDownloads" Style="{StaticResource IconBtn}"
                        Click="BtnDownloads_Click" ToolTip="Downloads  Ctrl+J"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Width="14" Height="14" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoDownload}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>

                        <Button x:Name="BtnMenu" Style="{StaticResource IconBtn}"
                        Click="BtnMenu_Click" ToolTip="Menu"
                        WindowChrome.IsHitTestVisibleInChrome="True">
                            <Path Width="14" Height="14" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoMenu}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                    </StackPanel>

                    <!-- Center: Address bar -->
                    <Border x:Name="AddrBorder"
                    Background="{StaticResource BgAddr}"
                    CornerRadius="20"
                    BorderBrush="{StaticResource BorderAddr}"
                    BorderThickness="1"
                    Padding="12,0"
                    WindowChrome.IsHitTestVisibleInChrome="True">
                        <DockPanel VerticalAlignment="Center">
                            <Path x:Name="LockIcon" DockPanel.Dock="Left"
                          Width="12" Height="12" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoLock}" Stroke="{StaticResource Green}"
                          Margin="0,0,8,0" Visibility="Collapsed"/>

                            <Path x:Name="GlobeIcon" DockPanel.Dock="Left"
                          Width="12" Height="12" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoGlobe}" Stroke="{StaticResource TextDim}"
                          Margin="0,0,8,0"/>

                            <TextBox x:Name="AddressBox" Style="{StaticResource AddrBox}"
                             VerticalAlignment="Center"
                             GotFocus="AddressBox_GotFocus"
                             LostFocus="AddressBox_LostFocus"
                             KeyDown="AddressBox_KeyDown"
                             TextChanged="AddressBox_TextChanged"
                             PreviewMouseDown="AddressBox_PreviewMouseDown"/>
                        </DockPanel>
                    </Border>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ROW 2: PROGRESS BAR -->
        <ProgressBar x:Name="LoadBar" Grid.Row="2"
                     Style="{StaticResource LoadBar}"
                     Visibility="Collapsed"/>

        <!-- ROW 3: BOOKMARKS BAR -->
        <Border x:Name="BookmarksBar" Grid.Row="3"
                Background="{StaticResource BgNav}"
                BorderBrush="{StaticResource Sep}"
                BorderThickness="0,0,0,1"
                Padding="10,0" Height="28" Visibility="Collapsed">
            <DockPanel>
                <Path DockPanel.Dock="Left" Width="10" Height="10"
                      Stretch="Uniform" Fill="Transparent" StrokeThickness="1.4"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      Data="{StaticResource IcoBookmarks}"
                      Stroke="{StaticResource TextDim}"
                      Margin="0,0,8,0" VerticalAlignment="Center"/>
                <StackPanel x:Name="BookmarkItems" Orientation="Horizontal" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- ROW 4: FIND BAR -->
        <Border x:Name="FindBarPanel" Grid.Row="4"
                Background="{StaticResource BgNav}"
                BorderBrush="{StaticResource Sep}"
                BorderThickness="0,0,0,1"
                Visibility="Collapsed" Padding="10,4">
            <DockPanel>
                <Button DockPanel.Dock="Right" Style="{StaticResource FindBtn}"
                        Click="BtnFindClose_Click">
                    <Path Width="9" Height="9" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoX}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button DockPanel.Dock="Right" Style="{StaticResource FindBtn}"
                        Click="BtnFindNext_Click">
                    <Path Width="9" Height="9" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoArrowDown}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <Button DockPanel.Dock="Right" Style="{StaticResource FindBtn}"
                        Click="BtnFindPrev_Click">
                    <Path Width="9" Height="9" Stretch="Uniform" Fill="Transparent"
                          StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="{StaticResource IcoArrowUp}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                </Button>
                <TextBlock x:Name="FindResult" DockPanel.Dock="Right"
                           VerticalAlignment="Center" Margin="6,0"
                           Foreground="{StaticResource TextSub}" FontSize="11"/>
                <Border Background="{StaticResource BgAddr}"
                        CornerRadius="6" BorderBrush="{StaticResource Border2}"
                        BorderThickness="1" Padding="8,3" MaxWidth="300">
                    <TextBox x:Name="FindBox" Style="{StaticResource FindBox}"
                             VerticalAlignment="Center"
                             TextChanged="FindBox_TextChanged"
                             KeyDown="FindBox_KeyDown"/>
                </Border>
                <TextBlock Text="Find in page" VerticalAlignment="Center"
                           Margin="0,0,10,0" Foreground="{StaticResource TextSub}" FontSize="11"/>
            </DockPanel>
        </Border>

        <!-- ROW 5: WEB CONTENT -->
        <Grid x:Name="WebHost" Grid.Row="5" Background="#FF080A0E" ClipToBounds="True"/>

        <!-- ROW 6: STATUS BAR -->
        <Border Grid.Row="6" Background="{StaticResource BgTitle}"
                BorderBrush="{StaticResource Sep}" BorderThickness="0,1,0,0"
                Padding="10,0">
            <DockPanel>
                <TextBlock x:Name="StatusText" DockPanel.Dock="Left"
                           VerticalAlignment="Center" FontSize="10.5"
                           Foreground="{StaticResource TextDim}" Text="Ready"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnZoomOut" Style="{StaticResource FindBtn}"
                            Width="20" Height="20" Click="BtnZoomOut_Click">
                        <Path Width="8" Height="8" Stretch="Uniform" Fill="Transparent"
                              StrokeThickness="2" Data="{StaticResource IcoZoomOut}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                    <TextBlock x:Name="ZoomLabel" Style="{StaticResource ZoomLabel}" Text="100%"/>
                    <Button x:Name="BtnZoomIn" Style="{StaticResource FindBtn}"
                            Width="20" Height="20" Click="BtnZoomIn_Click">
                        <Path Width="8" Height="8" Stretch="Uniform" Fill="Transparent"
                              StrokeThickness="2" Data="{StaticResource IcoZoomIn}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                    </Button>
                    <TextBlock Text="RuneS" FontSize="10" Foreground="{StaticResource TextDim}"
                               VerticalAlignment="Center" Margin="12,0,2,0" Opacity="0.5"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>