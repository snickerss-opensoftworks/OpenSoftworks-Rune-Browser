<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════════════════════
         RuneS  —  Combined Theme
         Carbon Blackout + Gloss Dark + Morpheon Dark
         Matte black base · Cool blue accent · Subtle gloss highlights
    ══════════════════════════════════════════════════════════════════════════ -->

    <!-- ── Palette ────────────────────────────────────────────────────────── -->
    <Color x:Key="C.BgWindow"      >#FF080A0E</Color>
    <Color x:Key="C.BgTitle"       >#FF0B0D11</Color>
    <Color x:Key="C.BgTabBar"      >#FF0D0F14</Color>
    <Color x:Key="C.BgTabActive"   >#FF1A1C22</Color>
    <Color x:Key="C.BgTabInactive" >#FF101217</Color>
    <Color x:Key="C.BgTabHover"    >#FF161820</Color>
    <Color x:Key="C.BgNav"         >#FF13151B</Color>
    <Color x:Key="C.BgAddr"        >#FF1C1E25</Color>
    <Color x:Key="C.BgAddrHover"   >#FF22242C</Color>
    <Color x:Key="C.BgFindBar"     >#FF161820</Color>
    <Color x:Key="C.BgMenu"        >#FF1A1C24</Color>
    <Color x:Key="C.BgHover"       >#FF1E2028</Color>
    <Color x:Key="C.BgPress"       >#FF262830</Color>

    <Color x:Key="C.Accent"        >#FF4D9EFF</Color>  <!-- Morpheon blue -->
    <Color x:Key="C.AccentDim"     >#FF2A6ECC</Color>
    <Color x:Key="C.AccentGlow"    >#334D9EFF</Color>
    <Color x:Key="C.Green"         >#FF4EC94E</Color>
    <Color x:Key="C.Orange"        >#FFFFA040</Color>
    <Color x:Key="C.Red"           >#FFE8223A</Color>

    <Color x:Key="C.Text"          >#FFF0F2F8</Color>
    <Color x:Key="C.TextSub"       >#FF8890A4</Color>
    <Color x:Key="C.TextDim"       >#FF44485A</Color>
    <Color x:Key="C.TextAddr"      >#FFD8DCE8</Color>

    <Color x:Key="C.Border"        >#FF1E2130</Color>
    <Color x:Key="C.BorderBright"  >#FF2E3245</Color>
    <Color x:Key="C.BorderAddr"    >#FF282C3A</Color>
    <Color x:Key="C.Sep"           >#FF161820</Color>

    <!-- Gloss highlight – very subtle lighter stripe on top of toolbars -->
    <Color x:Key="C.GlossTop"      >#14FFFFFF</Color>
    <Color x:Key="C.GlossBot"      >#00FFFFFF</Color>

    <!-- ── Brushes ─────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgWindowBrush"     Color="{StaticResource C.BgWindow}"/>
    <SolidColorBrush x:Key="BgTitleBrush"      Color="{StaticResource C.BgTitle}"/>
    <SolidColorBrush x:Key="BgTabBarBrush"     Color="{StaticResource C.BgTabBar}"/>
    <SolidColorBrush x:Key="BgTabActiveBrush"  Color="{StaticResource C.BgTabActive}"/>
    <SolidColorBrush x:Key="BgTabInactiveBrush" Color="{StaticResource C.BgTabInactive}"/>
    <SolidColorBrush x:Key="BgNavBrush"        Color="{StaticResource C.BgNav}"/>
    <SolidColorBrush x:Key="BgAddrBrush"       Color="{StaticResource C.BgAddr}"/>
    <SolidColorBrush x:Key="BgFindBarBrush"    Color="{StaticResource C.BgFindBar}"/>
    <SolidColorBrush x:Key="BgMenuBrush"       Color="{StaticResource C.BgMenu}"/>
    <SolidColorBrush x:Key="BgHoverBrush"      Color="{StaticResource C.BgHover}"/>
    <SolidColorBrush x:Key="BgPressBrush"      Color="{StaticResource C.BgPress}"/>

    <SolidColorBrush x:Key="AccentBrush"       Color="{StaticResource C.Accent}"/>
    <SolidColorBrush x:Key="AccentDimBrush"    Color="{StaticResource C.AccentDim}"/>
    <SolidColorBrush x:Key="GreenBrush"        Color="{StaticResource C.Green}"/>
    <SolidColorBrush x:Key="OrangeBrush"       Color="{StaticResource C.Orange}"/>
    <SolidColorBrush x:Key="RedBrush"          Color="{StaticResource C.Red}"/>
    <SolidColorBrush x:Key="GreenSecureBrush"  Color="{StaticResource C.Green}"/>

    <SolidColorBrush x:Key="TextBrush"         Color="{StaticResource C.Text}"/>
    <SolidColorBrush x:Key="TextSubBrush"      Color="{StaticResource C.TextSub}"/>
    <SolidColorBrush x:Key="TextDimBrush"      Color="{StaticResource C.TextDim}"/>
    <SolidColorBrush x:Key="TextAddrBrush"     Color="{StaticResource C.TextAddr}"/>

    <SolidColorBrush x:Key="BorderBrush_"      Color="{StaticResource C.Border}"/>
    <SolidColorBrush x:Key="BorderBrightBrush" Color="{StaticResource C.BorderBright}"/>
    <SolidColorBrush x:Key="BorderAddrBrush"   Color="{StaticResource C.BorderAddr}"/>
    <SolidColorBrush x:Key="SepBrush"          Color="{StaticResource C.Sep}"/>

    <!-- Gloss gradient (Carbon fibre gloss highlight on top edge of toolbars) -->
    <LinearGradientBrush x:Key="GlossBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="{StaticResource C.GlossTop}" Offset="0"/>
        <GradientStop Color="{StaticResource C.GlossBot}" Offset="1"/>
    </LinearGradientBrush>

    <!-- Accent glow for active tab indicator -->
    <LinearGradientBrush x:Key="AccentGlowBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource C.AccentGlow}" Offset="0"/>
        <GradientStop Color="{StaticResource C.Accent}"     Offset="0.5"/>
        <GradientStop Color="{StaticResource C.AccentGlow}" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Typography ──────────────────────────────────────────────────────── -->
    <FontFamily x:Key="UiFont">Segoe UI</FontFamily>

    <!-- ── Base TextBlock ──────────────────────────────────────────────────── -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <!-- ── Helper: Path icon that inherits Foreground → Stroke ─────────────
         Usage: <ContentControl Style="{StaticResource IconContent}" .../>  -->

    <!-- ── Icon Button ─────────────────────────────────────────────────────── -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderBrush"      Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Foreground"       Value="{StaticResource TextSubBrush}"/>
        <Setter Property="Width"            Value="34"/>
        <Setter Property="Height"           Value="34"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="5" Padding="6">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource BgHoverBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource BgPressBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.22"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Window control buttons ──────────────────────────────────────────── -->
    <Style x:Key="WinCtrlButtonStyle" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderBrush"      Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Foreground"       Value="{StaticResource TextDimBrush}"/>
        <Setter Property="Width"            Value="46"/>
        <Setter Property="Height"           Value="30"/>
        <Setter Property="Cursor"           Value="Arrow"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource BgHoverBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource BgPressBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CloseButtonStyle" TargetType="Button"
           BasedOn="{StaticResource WinCtrlButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource RedBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="#FFB01828"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Address bar TextBox ──────────────────────────────────────────────── -->
    <Style x:Key="AddressBoxStyle" TargetType="TextBox">
        <Setter Property="Background"               Value="Transparent"/>
        <Setter Property="BorderBrush"              Value="Transparent"/>
        <Setter Property="BorderThickness"          Value="0"/>
        <Setter Property="Foreground"               Value="{StaticResource TextAddrBrush}"/>
        <Setter Property="CaretBrush"               Value="{StaticResource TextBrush}"/>
        <Setter Property="SelectionBrush"           Value="{StaticResource AccentDimBrush}"/>
        <Setter Property="FontFamily"               Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"                 Value="12.5"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle"         Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Hidden"
                                  Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Small find-bar TextBox -->
    <Style x:Key="FindBoxStyle" TargetType="TextBox" BasedOn="{StaticResource AddressBoxStyle}">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
    </Style>

    <!-- ── Tab button ────────────────────────────────────────────────────────── -->
    <Style x:Key="TabButtonStyle" TargetType="Button">
        <Setter Property="Background"       Value="{StaticResource BgTabInactiveBrush}"/>
        <Setter Property="BorderBrush"      Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Foreground"       Value="{StaticResource TextSubBrush}"/>
        <Setter Property="FontFamily"       Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"         Value="11.5"/>
        <Setter Property="Height"           Value="34"/>
        <Setter Property="MinWidth"         Value="100"/>
        <Setter Property="MaxWidth"         Value="200"/>
        <Setter Property="Padding"          Value="8,0,4,0"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5,5,0,0"
                                Margin="1,3,1,0">
                            <!-- Gloss overlay -->
                            <Border.OpacityMask>
                                <VisualBrush/>
                            </Border.OpacityMask>
                        </Border>
                        <!-- Gloss shine on top -->
                        <Border x:Name="Gloss"
                                CornerRadius="5,5,0,0"
                                Margin="1,3,1,0"
                                Background="{StaticResource GlossBrush}"
                                IsHitTestVisible="False" Opacity="0"/>
                        <!-- Content -->
                        <ContentPresenter x:Name="CP"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"
                                          RecognizesAccessKey="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background">
                                <Setter.Value>
                                    <SolidColorBrush Color="{StaticResource C.BgTabHover}"/>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="Gloss" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── New-tab (+) button ──────────────────────────────────────────────── -->
    <Style x:Key="NewTabButtonStyle" TargetType="Button"
           BasedOn="{StaticResource IconButtonStyle}">
        <Setter Property="Width"  Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Margin" Value="2,3,6,2"/>
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <!-- ── Bookmark-bar button ─────────────────────────────────────────────── -->
    <Style x:Key="BookmarkBarButtonStyle" TargetType="Button">
        <Setter Property="Background"       Value="Transparent"/>
        <Setter Property="BorderBrush"      Value="Transparent"/>
        <Setter Property="BorderThickness"  Value="0"/>
        <Setter Property="Foreground"       Value="{StaticResource TextSubBrush}"/>
        <Setter Property="FontFamily"       Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"         Value="11"/>
        <Setter Property="Padding"          Value="7,2"/>
        <Setter Property="Height"           Value="22"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource BgHoverBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background"
                                    Value="{StaticResource BgPressBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Find-bar compact button ─────────────────────────────────────────── -->
    <Style x:Key="FindBarButtonStyle" TargetType="Button"
           BasedOn="{StaticResource IconButtonStyle}">
        <Setter Property="Width"  Value="26"/>
        <Setter Property="Height" Value="26"/>
    </Style>

    <!-- ── Load progress bar ───────────────────────────────────────────────── -->
    <Style x:Key="LoadBarStyle" TargetType="ProgressBar">
        <Setter Property="Height"          Value="2"/>
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderBrush"     Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="{StaticResource AccentBrush}"/>
        <Setter Property="IsIndeterminate" Value="True"/>
    </Style>

    <!-- ── Zoom label ──────────────────────────────────────────────────────── -->
    <Style x:Key="ZoomLabelStyle" TargetType="TextBlock"
           BasedOn="{StaticResource {x:Type TextBlock}}">
        <Setter Property="Foreground" Value="{StaticResource TextSubBrush}"/>
        <Setter Property="FontSize"   Value="10.5"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin"     Value="2,0"/>
        <Setter Property="Width"      Value="36"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <!-- ── ScrollBar ───────────────────────────────────────────────────────── -->
    <Style TargetType="ScrollBar">
        <Setter Property="Width"      Value="6"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

</ResourceDictionary>
